generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

model WebsiteCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  icon      String
  basePrice Int
  features  String   // comma-separated features
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AddOn {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  price     Int
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PageOption {
  id          String   @id @default(cuid())
  label       String   @unique
  slug        String   @unique
  description String
  extraPrice  Int
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PortfolioProject {
  id          String   @id @default(cuid())
  name        String
  category    String
  description String
  gradient    String
  websiteUrl  String?  // URL to demo website
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
